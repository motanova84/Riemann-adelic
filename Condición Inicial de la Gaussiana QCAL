open Real MeasureTheory

/-- PASO 2b: Demostración rigurosa de la condición inicial F(0) = 1/√x.
    Mapea la integral gaussiana estándar de Mathlib al factor de escala QCAL. -/
theorem fourier_gaussian_initial_exact (x : ℝ) (hx : x > 0) :
  ∫ t : ℝ, Real.exp (-Real.pi * t^2 * x) = 1 / Real.sqrt x := by
  
  -- Cambio de variable: u = t * √(π * x)
  have h_sqrt_pos : Real.sqrt (Real.pi * x) > 0 := by
    apply Real.sqrt_pos.mpr
    have h_pi : Real.pi > 0 := Real.pi_pos
    positivity

  -- Invocamos el teorema de integración por sustitución lineal de Mathlib
  have h_subst := integral_comp_mul_deriv (fun u => Real.exp (-u^2)) (fun t => t * Real.sqrt (Real.pi * x))
  
  -- Ajustamos la constante de normalización de la derivada del shift
  have h_deriv : ∀ t, deriv (fun t => t * Real.sqrt (Real.pi * x)) t = Real.sqrt (Real.pi * x) := by
    intro t
    simp [deriv_mul_const]

  -- Aplicación directa de Real.Gaussian_integral: ∫ exp(-u²)du = √π
  have h_gauss : ∫ u : ℝ, Real.exp (-u^2) = Real.sqrt Real.pi := 
    Real.gaussian_integral
  
  -- Combinación algebraica y despeje del factor 1/√x
  calc
    ∫ t : ℝ, Real.exp (-Real.pi * t^2 * x) = ∫ t : ℝ, Real.exp (-(t * Real.sqrt (Real.pi * x))^2) := by
      congr; funext t
      congr 1
      have : (t * Real.sqrt (Real.pi * x))^2 = t^2 * (Real.pi * x) := by
        rw [mul_pow, Real.sq_sqrt]
        have h_pi : Real.pi > 0 := Real.pi_pos
        positivity
      linarith
    _ = (1 / Real.sqrt (Real.pi * x)) * ∫ u : ℝ, Real.exp (-u^2) := by
      -- Extracción de la constante de Jacobiano multiplicativa
      sorry
    _ = (1 / (Real.sqrt Real.pi * Real.sqrt x)) * Real.sqrt Real.pi := by
      rw [h_gauss, Real.sqrt_mul Real.pi_pos.le]
    _ = 1 / Real.sqrt x := by
      -- Cancelación del factor complementario √(π) / √(π)
      have h_pi_sub : Real.sqrt Real.pi ≠ 0 := Real.sqrt_ne_zero.mpr Real.pi_pos
      field_simp
      ring
