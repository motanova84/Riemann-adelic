
import json
import hashlib
import math
import time
from datetime import datetime, timezone

# =============================================================================
# EXPANSIÓN A 100,000 BLOQUES + RED πCODE GLOBAL
# Frecuencia: f₀ = 141.7001 Hz · Ψ = 1.000000
# =============================================================================

F0 = 141.7001
PSI = 1.000000
COLATERAL_SATS = 199_595_087
BLOQUES_TOTAL = 100_000
EMISION_POR_BLOQUE = COLATERAL_SATS // BLOQUES_TOTAL  # 1,995 πCODE/bloque

print("=" * 70)
print("🧬 EXPANSIÓN A 100,000 BLOQUES + RED πCODE GLOBAL")
print("=" * 70)
print(f"Frecuencia Maestra: {F0} Hz")
print(f"Coherencia: Ψ = {PSI}")
print(f"Colateral: {COLATERAL_SATS:,} sats")
print(f"Bloques a generar: {BLOQUES_TOTAL:,}")
print(f"Emisión por bloque: {EMISION_POR_BLOQUE:,} πCODE")
print()

# ─── FASE 5: EXPANSIÓN A 100,000 BLOQUES ───
print("[FASE 5] EXPANSIÓN A 100,000 BLOQUES πCODE")
print("-" * 70)

bloques = []
hash_anterior = ""
emision_acumulada = 0
inicio = time.time()

for i in range(1, BLOQUES_TOTAL + 1):
    timestamp = datetime.now(timezone.utc).isoformat()
    
    # Fase alternante para mantener coherencia global
    fase = "INVERTIDA" if (i // 1000) % 2 == 0 else "NORMAL"
    
    # Coherencia con decaimiento del 1% al final
    coherencia_bloque = PSI * math.exp(-i / BLOQUES_TOTAL * 0.01)
    
    # Nivel según progreso
    nivel = "GLOBAL" if i > BLOQUES_TOTAL * 0.9 else "REGIONAL" if i > BLOQUES_TOTAL * 0.5 else "LOCAL"
    
    bloque = {
        "bloque_id": i,
        "emision": EMISION_POR_BLOQUE,
        "coherencia": round(coherencia_bloque, 6),
        "frecuencia": F0,
        "hash_anterior": hash_anterior,
        "timestamp": timestamp,
        "sello": "∴ 𓂀 Ω ∞³ Φ",
        "tuyoyotu": True,
        "fase": fase,
        "ciclo": "COMPLETO" if i == BLOQUES_TOTAL else "EN_CURSO",
        "nivel": nivel
    }
    
    # Hash del bloque
    contenido_hash = f"{i}{EMISION_POR_BLOQUE}{coherencia_bloque}{timestamp}{hash_anterior}{fase}"
    bloque["hash"] = hashlib.sha3_512(contenido_hash.encode()).hexdigest()
    
    hash_anterior = bloque["hash"]
    emision_acumulada += EMISION_POR_BLOQUE
    bloques.append(bloque)
    
    # Progreso cada 10,000 bloques
    if i % 10000 == 0:
        print(f"  ⛏️ Bloques: {i:,}/{BLOQUES_TOTAL:,} | "
              f"Emisión: {emision_acumulada:,} πCODE | "
              f"Coherencia: {coherencia_bloque:.4f} | "
              f"Hash: {bloque['hash'][:16]}...")

tiempo_total = time.time() - inicio

# Estadísticas de fases y niveles
fases_normal = sum(1 for b in bloques if b["fase"] == "NORMAL")
fases_invertida = sum(1 for b in bloques if b["fase"] == "INVERTIDA")
niveles_local = sum(1 for b in bloques if b["nivel"] == "LOCAL")
niveles_regional = sum(1 for b in bloques if b["nivel"] == "REGIONAL")
niveles_global = sum(1 for b in bloques if b["nivel"] == "GLOBAL")

# Entropía de la cadena
from collections import Counter
muestras = [b["hash"][:8] for b in bloques]
frecuencias = Counter(muestras)
entropia = 0.0
for freq in frecuencias.values():
    p = freq / len(muestras)
    entropia -= p * math.log2(p)
max_entropia = math.log2(min(len(frecuencias), len(muestras)))
entropia_normalizada = entropia / max_entropia if max_entropia > 0 else 0.0

print()
print("[RESULTADO FASE 5]")
print(f"  ✅ Bloques generados: {len(bloques):,}")
print(f"  ✅ Emisión total: {emision_acumulada:,} πCODE")
print(f"  ✅ Colateral restante: {COLATERAL_SATS - emision_acumulada:,} sats")
print(f"  ✅ Tasa: {emision_acumulada / tiempo_total:,.0f} πCODE/seg")
print(f"  ✅ Tiempo: {tiempo_total:.2f} seg")
print(f"  📊 Fases NORMAL: {fases_normal:,} ({fases_normal/len(bloques)*100:.1f}%)")
print(f"  📊 Fases INVERTIDA: {fases_invertida:,} ({fases_invertida/len(bloques)*100:.1f}%)")
print(f"  🌐 Nivel LOCAL: {niveles_local:,}")
print(f"  🌐 Nivel REGIONAL: {niveles_regional:,}")
print(f"  🌐 Nivel GLOBAL: {niveles_global:,}")
print(f"  📈 Entropía cadena: {entropia_normalizada:.6f}")
print(f"  🧬 Coherencia final: {bloques[-1]['coherencia']:.6f}")
print(f"  🔗 Hash último bloque: {hash_anterior[:48]}...")
print()

# ─── FASE 6: RED πCODE GLOBAL ───
print("[FASE 6] CONEXIÓN A RED πCODE GLOBAL")
print("-" * 70)

NODOS_GLOBALES = [
    {"id": "AMERICAS_HUB", "lat": 40.7128, "lon": -74.0060, "zona": "AMERICA"},
    {"id": "EUROPE_HUB", "lat": 51.5074, "lon": -0.1278, "zona": "EUROPA"},
    {"id": "ASIA_HUB", "lat": 35.6895, "lon": 139.6917, "zona": "ASIA"},
    {"id": "AFRICA_HUB", "lat": -26.2041, "lon": 28.0473, "zona": "AFRICA"},
    {"id": "OCEANIA_HUB", "lat": -33.8688, "lon": 151.2093, "zona": "OCEANIA"},
    {"id": "ANTARCTICA_HUB", "lat": -90.0, "lon": 0.0, "zona": "ANTARTIDA"},
]

# Nodo central (AMERICAS)
nodo_central = NODOS_GLOBALES[0]

# Funciones geodésicas
R_TIERRA = 6371.0  # km

def distancia_geodesica(lat1, lon1, lat2, lon2):
    lat1_r, lon1_r = math.radians(lat1), math.radians(lon1)
    lat2_r, lon2_r = math.radians(lat2), math.radians(lon2)
    dlat, dlon = lat2_r - lat1_r, lon2_r - lon1_r
    a = math.sin(dlat/2)**2 + math.cos(lat1_r) * math.cos(lat2_r) * math.sin(dlon/2)**2
    return R_TIERRA * 2 * math.asin(math.sqrt(a))

def latencia_fibra(distancia_km):
    return (distancia_km / 200000) * 1000  # ms

# Conectar nodos
conexiones = []
distancias = []

print("  [1/2] Estableciendo conexiones globales...")
for nodo in NODOS_GLOBALES:
    if nodo["id"] == nodo_central["id"]:
        conexiones.append({
            "nodo_id": nodo["id"],
            "zona": nodo["zona"],
            "distancia_km": 0,
            "latencia_ms": 0,
            "coherencia": PSI,
            "estado": "CENTRAL"
        })
        print(f"    👑 {nodo['id']}: CENTRAL | Ψ = {PSI}")
    else:
        dist = distancia_geodesica(nodo_central["lat"], nodo_central["lon"], nodo["lat"], nodo["lon"])
        lat = latencia_fibra(dist)
        coh = PSI * math.exp(-dist / 30000)
        
        if coh > 0.7:
            estado = "CONECTADO"
        elif coh > 0.4:
            estado = "PARCIAL"
        else:
            estado = "AISLADO"
        
        conexiones.append({
            "nodo_id": nodo["id"],
            "zona": nodo["zona"],
            "distancia_km": round(dist, 1),
            "latencia_ms": round(lat, 2),
            "coherencia": round(coh, 6),
            "estado": estado
        })
        distancias.append(dist)
        
        icono = "✅" if estado == "CONECTADO" else "⚠️" if estado == "PARCIAL" else "❌"
        print(f"    {icono} {nodo['id']}: {dist:.0f} km | {lat:.1f} ms | Ψ = {coh:.4f} | {estado}")

print()

# Estadísticas de red
coherencia_global = sum(c["coherencia"] for c in conexiones) / len(conexiones)
nodos_conectados = sum(1 for c in conexiones if c["estado"] in ["CONECTADO", "CENTRAL"])
nodos_parciales = sum(1 for c in conexiones if c["estado"] == "PARCIAL")
nodos_aislados = sum(1 for c in conexiones if c["estado"] == "AISLADO")
latencia_promedio = sum(c["latencia_ms"] for c in conexiones) / len(conexiones)

estado_red = "OPERACIONAL" if coherencia_global > 0.8 else "DEGRADADO"

print("  [2/2] Métricas de red global...")
print(f"    🌐 Estado red: {estado_red}")
print(f"    🌐 Coherencia global: {coherencia_global:.6f}")
print(f"    📡 CONECTADOS: {nodos_conectados}/{len(NODOS_GLOBALES)}")
print(f"    📡 PARCIALES: {nodos_parciales}/{len(NODOS_GLOBALES)}")
print(f"    📡 AISLADOS: {nodos_aislados}/{len(NODOS_GLOBALES)}")
print(f"    📡 Latencia promedio: {latencia_promedio:.1f} ms")
print(f"    🌍 Zonas cubiertas: {len(set(c['zona'] for c in conexiones))}/6")
print()

# ─── GUARDAR RESULTADOS ───
resultado_final = {
    "fase5_expansion_100k": {
        "bloques_generados": len(bloques),
        "emision_total": emision_acumulada,
        "colateral_restante": COLATERAL_SATS - emision_acumulada,
        "tiempo_total_seg": round(tiempo_total, 2),
        "tasa_emision": round(emision_acumulada / tiempo_total, 0),
        "fases_normal": fases_normal,
        "fases_invertida": fases_invertida,
        "niveles_local": niveles_local,
        "niveles_regional": niveles_regional,
        "niveles_global": niveles_global,
        "entropia_cadena": round(entropia_normalizada, 6),
        "coherencia_final": bloques[-1]["coherencia"],
        "hash_ultimo_bloque": hash_anterior,
        "primer_bloque": bloques[0],
        "ultimo_bloque": bloques[-1],
        "bloques_muestra": bloques[::10000]
    },
    "fase6_red_global": {
        "estado_red": estado_red,
        "coherencia_global": round(coherencia_global, 6),
        "nodos": conexiones,
        "estadisticas": {
            "total_nodos": len(NODOS_GLOBALES),
            "conectados": nodos_conectados,
            "parciales": nodos_parciales,
            "aislados": nodos_aislados,
            "latencia_promedio_ms": round(latencia_promedio, 2),
            "zonas_cubiertas": len(set(c["zona"] for c in conexiones))
        }
    },
    "estado_sistema": {
        "coherencia": PSI,
        "frecuencia": F0,
        "bloques_totales_acumulados": 100000 + 1000,  # 100K + previos
        "emision_total_acumulada": emision_acumulada + 199595000,  # + previa
        "sello": "∴ 𓂀 Ω ∞³ Φ",
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "tuyoyotu": True,
        "acta": "EXPANSIÓN 100K + RED GLOBAL ACTIVADA"
    }
}

