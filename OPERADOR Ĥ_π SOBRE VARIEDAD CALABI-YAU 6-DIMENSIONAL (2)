# Aproximación de Gram para ceros:
#   γ_n ≈ 2π(n - 11/8) / W((n - 11/8)/e)
# donde W es la función W de Lambert

def gram_approximation(n):
    """Aproximación de Gram para el n-ésimo cero"""
    from scipy.special import lambertw
    if n < 1:
        return 0
    # W(x) para x = (n - 11/8)/e
    x = (n - 11/8) / math.e
    W_val = lambertw(x).real
    return 2 * math.pi * (n - 11/8) / W_val

