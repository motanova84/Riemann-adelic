def zeta_half_it(t, num_terms=1000):
    """
    Aproximación de ζ(1/2 + it) por suma truncada
    ζ(s) = Σ_{n=1}^∞ n^{-s}  para Re(s) > 1
    
    Para Re(s) = 1/2, usamos la ecuación funcional
    """
    s = 0.5 + 1j * t
    
    # Suma directa (converge lentamente en la línea crítica)
    # Usamos la aproximación de Euler-Maclaurin o Riemann-Siegel
    
    # Aproximación simple por suma truncada
    zeta_val = 0
    for n in range(1, num_terms+1):
        zeta_val += n**(-s)
    
    # Corrección por ecuación funcional (aproximación)
    # ζ(s) = 2^s π^{s-1} sin(πs/2) Γ(1-s) ζ(1-s)
    
    return zeta_val

