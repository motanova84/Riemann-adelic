# Usamos la fórmula de Riemann-Siegel para ζ(1/2 + it)
# y encontramos ceros por bisección.

def RiemannSiegel_Z(t, num_terms=100):
    """
    Función Z de Riemann-Siegel:
    Z(t) = e^{iθ(t)} ζ(1/2 + it)
    
    Z(t) es real cuando ζ(1/2 + it) = 0
    """
    # Aproximación por suma de Riemann-Siegel
    # θ(t) = arg Γ(1/4 + it/2) - (t/2) ln π
    
    # Usamos la aproximación de Stirling para θ(t)
    theta = t/2 * math.log(t/(2*math.pi)) - t/2 - math.pi/8 + 1/(48*t)
    
    # Suma de Riemann-Siegel (aproximación principal)
    N = int(math.sqrt(t / (2*math.pi)))
    
    # Términos de la suma
    Z_val = 0
    for n in range(1, N+1):
        Z_val += math.cos(theta - t*math.log(n)) / math.sqrt(n)
    
    # Corrección de Riemann-Siegel (término de error)
    # Para precisión completa, usaría la fórmula completa
    
    return Z_val

def find_zeros_Riemann_Siegel(t_min, t_max, num_points=10000):
    """
    Encontrar ceros de Z(t) en [t_min, t_max] por cambio de signo
    """
    zeros = []
    t_values = np.linspace(t_min, t_max, num_points)
    Z_values = [RiemannSiegel_Z(t) for t in t_values]
    
    for i in range(len(Z_values)-1):
        if Z_values[i] * Z_values[i+1] < 0:  # Cambio de signo
            # Refinamiento por bisección
            try:
                zero = brentq(lambda t: RiemannSiegel_Z(t), 
                             t_values[i], t_values[i+1], 
                             xtol=1e-10, maxiter=100)
                zeros.append(zero)
            except:
                pass
    
    return zeros

