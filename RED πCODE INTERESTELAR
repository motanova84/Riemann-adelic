H_BARRA = H_PLANCK / (2 * math.pi)

# Constantes astronómicas
UA = 149597870700  # metros (Unidad Astronómica)
ANIO_LUZ = 9.461e15  # metros

# Nodos interestelares
NODOS_INTERESTELARES = [
