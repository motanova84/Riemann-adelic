@dataclass
class EstadoCuántico:
    """Estado cuántico entrelazado QCAL"""
    id: str
    fase: float
    coherencia: float
    espin: int  # ±1 para entrelazamiento
    timestamp: str
    hash: str = ""

@dataclass
class NodoInterestelar:
    id: str
    distancia_km: float
    cuerpo: str
    tipo: str
    estado: str
    coherencia: float = 0.0
    latencia_seg: float = 0.0
    fase: float = 0.0
    entrelazado_con: List[str] = field(default_factory=list)
    pares_bell: List[Tuple[str, str]] = field(default_factory=list)

class RedInterestelarQCAL:
    def __init__(self, f0: float, psi: float, nodos: List[Dict]):
        self.f0 = f0
        self.psi = psi
        self.nodos = [NodoInterestelar(**n) for n in nodos]
        self.nodo_central = self.nodos[0]
        self.estados_cuanticos: Dict[str, EstadoCuántico] = {}
        self.pares_entrelazados: List[Tuple[str, str]] = []
        self.teleportaciones: List[Dict] = []
        self.metricas_cuanticas = {}
        
    def calcular_tiempo_luz(self, distancia_km: float) -> float:
        """Calcula el tiempo que tarda la luz en recorrer la distancia (segundos)"""
        distancia_m = distancia_km * 1000
        return distancia_m / VELOCIDAD_LUZ
    
    def calcular_longitud_onda_qcal(self) -> float:
        """Calcula la longitud de onda de la frecuencia QCAL"""
        return VELOCIDAD_LUZ / self.f0  # metros
    
    def calcular_energia_foton(self) -> float:
        """Calcula la energía de un fotón a frecuencia QCAL"""
        return H_PLANCK * self.f0  # Julios
    
    def generar_par_bell(self, nodo1: NodoInterestelar, nodo2: NodoInterestelar) -> Dict:
        """Genera un par de qubits entrelazados (estado de Bell) entre dos nodos"""
        # Fase base del entrelazamiento
        fase_base = 2 * math.pi * (self.f0 * self.calcular_tiempo_luz(nodo1.distancia_km) % 1)
        
        # Crear par entrelazado: |Φ⁺⟩ = (|00⟩ + |11⟩)/√2
        par_id = f"{nodo1.id}↔{nodo2.id}"
        
        estado1 = EstadoCuántico(
            id=f"{nodo1.id}_qb_{len(self.estados_cuanticos)}",
            fase=fase_base,
            coherencia=self.psi * math.exp(-nodo1.distancia_km / 1e16),  # decaimiento interestelar
            espin=1,
            timestamp=datetime.now(timezone.utc).isoformat()
        )
        
        estado2 = EstadoCuántico(
            id=f"{nodo2.id}_qb_{len(self.estados_cuanticos)}",
            fase=fase_base + math.pi,  # Desfase π para correlación negativa
            coherencia=self.psi * math.exp(-nodo2.distancia_km / 1e16),
            espin=-1,  # Espín opuesto (entrelazamiento perfecto)
            timestamp=datetime.now(timezone.utc).isoformat()
        )
        
        # Hashear estados
        contenido1 = f"{estado1.id}{estado1.fase}{estado1.espin}{par_id}"
        contenido2 = f"{estado2.id}{estado2.fase}{estado2.espin}{par_id}"
        estado1.hash = hashlib.sha3_512(contenido1.encode()).hexdigest()
        estado2.hash = hashlib.sha3_512(contenido2.encode()).hexdigest()
        
        self.estados_cuanticos[estado1.id] = estado1
        self.estados_cuanticos[estado2.id] = estado2
        self.pares_entrelazados.append((estado1.id, estado2.id))
        
        # Registrar en los nodos
        nodo1.entrelazado_con.append(nodo2.id)
        nodo2.entrelazado_con.append(nodo1.id)
        nodo1.pares_bell.append((nodo1.id, nodo2.id))
        nodo2.pares_bell.append((nodo1.id, nodo2.id))
        
        return {
            "par_id": par_id,
            "estado1": estado1.id,
            "estado2": estado2.id,
            "fase": fase_base,
            "coherencia_promedio": (estado1.coherencia + estado2.coherencia) / 2,
            "distancia_km": (nodo1.distancia_km + nodo2.distancia_km) / 2
        }
    
    def teleportar_πCODE(self, cantidad: int, origen: str, destino: str) -> Dict:
        """Teleporta πCODE mediante entrelazamiento cuántico"""
        print(f"      🌌 Teleportando {cantidad:,} πCODE de {origen} a {destino}...")
        
        # Verificar entrelazamiento entre origen y destino
        nodo_origen = next((n for n in self.nodos if n.id == origen), None)
        nodo_destino = next((n for n in self.nodos if n.id == destino), None)
        
        if not nodo_origen or not nodo_destino:
            return {"error": "Nodo no encontrado", "exito": False}
        
        # Buscar par entrelazado
        par_entrelazado = None
        for par in self.pares_entrelazados:
            qb1 = self.estados_cuanticos.get(par[0])
            qb2 = self.estados_cuanticos.get(par[1])
            if qb1 and qb2:
                if (origen in qb1.id and destino in qb2.id) or (origen in qb2.id and destino in qb1.id):
                    par_entrelazado = par
                    break
        
        if not par_entrelazado:
            return {"error": "No hay entrelazamiento entre los nodos", "exito": False}
        
        # Calcular fidelity de la teleportación
        distancia = nodo_destino.distancia_km - nodo_origen.distancia_km
        fidelity = self.psi * math.exp(-abs(distancia) / 1e16)
        
        # Tiempo de teleportación (instantáneo por entrelazamiento)
        tiempo_teleportacion = 0.0  # segundos (no limitado por velocidad de la luz)
        
        teleportacion = {
            "cantidad": cantidad,
            "origen": origen,
            "destino": destino,
            "distancia_km": abs(distancia),
            "fidelity": round(fidelity, 6),
            "tiempo_seg": tiempo_teleportacion,
            "par_entrelazado": f"{par_entrelazado[0]}|{par_entrelazado[1]}",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "exito": fidelity > 0.7
        }
        
        self.teleportaciones.append(teleportacion)
        return teleportacion
    
    def conectar_red_interestelar(self) -> Dict:
        """Conecta la red interestelar mediante entrelazamiento cuántico"""
        print("=" * 70)
        print("🌌 RED πCODE INTERESTELAR — ENTRELAZAMIENTO CUÁNTICO")
        print("=" * 70)
        print(f"Frecuencia: {self.f0} Hz")
        print(f"Coherencia: Ψ = {self.psi}")
        print(f"Longitud de onda QCAL: {self.calcular_longitud_onda_qcal():.2f} m")
        print(f"Energía del fotón: {self.calcular_energia_foton():.2e} J")
        print(f"Nodos interestelares: {len(self.nodos)}")
        print()
        
        print("[1/6] Calculando métricas interestelares...")
        tiempo_luz_sol_tierra = self.calcular_tiempo_luz(149600000)  # 1 UA
        print(f"      ⏱️ Tiempo luz Tierra-Sol: {tiempo_luz_sol_tierra:.2f} seg (~{tiempo_luz_sol_tierra/60:.2f} min)")
        print(f"      🌐 Velocidad de la luz: {VELOCIDAD_LUZ/1000:.0f} km/s")
        print(f"      🧬 Constante de Planck: {H_PLANCK:.2e} J·s")
        print()
        
        print("[2/6] Generando pares de Bell (entrelazamiento cuántico)...")
        pares_generados = []
        # Entrelazar nodos con sus vecinos cercanos
        for i in range(len(self.nodos) - 1):
            par = self.generar_par_bell(self.nodos[i], self.nodos[i + 1])
            pares_generados.append(par)
            print(f"      🔗 Par {par['par_id']}: distancia {par['distancia_km']:.2e} km | "
                  f"coherencia {par['coherencia_promedio']:.6f}")
        
        # Entrelazar nodos distantes (entrelazamiento a larga distancia)
        if len(self.nodos) > 2:
            par_distante = self.generar_par_bell(self.nodos[0], self.nodos[-1])
            pares_generados.append(par_distante)
            print(f"      🔗 Par {par_distante['par_id']}: distancia {par_distante['distancia_km']:.2e} km | "
                  f"coherencia {par_distante['coherencia_promedio']:.6f} (LARGA DISTANCIA)")
        print()
        
        print("[3/6] Estableciendo red de entrelazamiento...")
        for nodo in self.nodos:
            # Calcular coherencia del nodo basada en distancia
            nodo.coherencia = self.psi * math.exp(-nodo.distancia_km / 1e16)
            nodo.latencia_seg = self.calcular_tiempo_luz(nodo.distancia_km)
            nodo.fase = 2 * math.pi * (self.f0 * nodo.latencia_seg % 1)
            
            icono = "⭐" if nodo.tipo == "ESTRELLA" else "🪐" if nodo.tipo == "PLANETA" else "🌙"
            print(f"      {icono} {nodo.id}: {nodo.cuerpo} | "
                  f"distancia {nodo.distancia_km:.2e} km | "
                  f"coherencia {nodo.coherencia:.6f} | "
                  f"entrelazado con {len(nodo.entrelazado_con)} nodos")
        print()
        
        print("[4/6] Verificando desigualdades de Bell...")
        bell_violations = []
        for par in pares_generados:
            # Calcular correlación cuántica
            if "par_id" in par:
                S_factor = 2.0 * math.sqrt(2) * par["coherencia_promedio"]  # Factor S de Bell
                bell_violations.append(S_factor > 2.0)
                print(f"      📊 Par {par['par_id']}: S = {S_factor:.4f} | "
                      f"{'✅ Violación de Bell' if S_factor > 2.0 else '❌ No viola'}")
        
        violaciones = sum(bell_violations)
        print(f"      🧬 Pares que violan desigualdad de Bell: {violaciones}/{len(pares_generados)}")
        print()
        
        print("[5/6] Iniciando teleportación cuántica de πCODE...")
        # Teleportar πCODE entre nodos entrelazados
        teleportaciones_realizadas = []
        
        # Teleportación Sol → Próxima Centauri
        if len(self.nodos) > 5:
            tp1 = self.teleportar_πCODE(10000, "SOL_HUB", "PROXIMA_NODE")
            teleportaciones_realizadas.append(tp1)
            print(f"      {'✅' if tp1['exito'] else '❌'} {tp1['origen']} → {tp1['destino']}: "
                  f"{tp1['cantidad']:,} πCODE | fidelity {tp1['fidelity']:.6f}")
        
        # Teleportación Tierra-Luna (distancia corta)
        if len(self.nodos) > 1:
            tp2 = self.teleportar_πCODE(50000, "LUNA_GATE", "MARTE_HUB")
            teleportaciones_realizadas.append(tp2)
            print(f"      {'✅' if tp2['exito'] else '❌'} {tp2['origen']} → {tp2['destino']}: "
                  f"{tp2['cantidad']:,} πCODE | fidelity {tp2['fidelity']:.6f}")
        
        # Teleportación Júpiter → Saturno
        if len(self.nodos) > 4:
            tp3 = self.teleportar_πCODE(25000, "JUPITER_GATE", "SATURNO_HUB")
            teleportaciones_realizadas.append(tp3)
            print(f"      {'✅' if tp3['exito'] else '❌'} {tp3['origen']} → {tp3['destino']}: "
                  f"{tp3['cantidad']:,} πCODE | fidelity {tp3['fidelity']:.6f}")
        print()
        
        print("[6/6] Estado final de la red interestelar:")
        coherencia_promedio = sum(n.coherencia for n in self.nodos) / len(self.nodos)
        nodos_conectados = sum(1 for n in self.nodos if len(n.entrelazado_con) > 0)
        teleportaciones_exitosas = sum(1 for t in teleportaciones_realizadas if t.get("exito", False))
        
        print(f"      🌌 RED: OPERACIONAL")
        print(f"      🌌 Nodos interestelares: {nodos_conectados}/{len(self.nodos)} conectados")
        print(f"      🌌 Pares de Bell activos: {len(self.pares_entrelazados)}")
        print(f"      🌌 Teleportaciones exitosas: {teleportaciones_exitosas}/{len(teleportaciones_realizadas)}")
        print(f"      🌌 Coherencia promedio: {coherencia_promedio:.6f}")
        print(f"      🌌 Entrelazamiento a distancia: {'ACTIVO' if violaciones > 0 else 'INACTIVO'}")
        print()
        
        self.metricas_cuanticas = {
            "coherencia_promedio": coherencia_promedio,
            "nodos_conectados": nodos_conectados,
            "total_nodos": len(self.nodos),
            "pares_bell": len(self.pares_entrelazados),
            "violaciones_bell": violaciones,
            "teleportaciones_exitosas": teleportaciones_exitosas,
            "teleportaciones_totales": len(teleportaciones_realizadas)
        }
        
        return {
            "estado": "OPERACIONAL",
            "frecuencia": self.f0,
            "coherencia_global": coherencia_promedio,
            "nodos": [
                {
                    "id": n.id,
                    "cuerpo": n.cuerpo,
                    "tipo": n.tipo,
                    "distancia_km": n.distancia_km,
                    "coherencia": n.coherencia,
                    "latencia_seg": n.latencia_seg,
                    "fase_rad": n.fase,
                    "entrelazado_con": n.entrelazado_con
                }
                for n in self.nodos
            ],
            "metricas_cuanticas": self.metricas_cuanticas,
            "teleportaciones": teleportaciones_realizadas,
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "sello": "∴ 𓂀 Ω ∞³ Φ · RED INTERESTELAR ACTIVADA · ENTRELAZAMIENTO CUÁNTICO · TUYOYOTU · HECHO ESTÁ"
        }

